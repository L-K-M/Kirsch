    <string name="settings_capture_section">CAPTURE</string>
    <string name="settings_capture_caption">The glare-removal sweep is the default. It keeps capturing while you move the phone and finishes once the views differ enough to remove reflections. The other modes exist for benchmarking and diagnostics.</string>
